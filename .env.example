# === Telegram (required) ===

# Bot token (get from @BotFather)
BRIDGE_TELEGRAM_TOKEN=your_bot_token_here

# Authorized Telegram user IDs (comma-separated)
BRIDGE_ALLOWED_USERS=123456789

# === Server ===

# Web terminal port
BRIDGE_WEB_PORT=8088

# Web server bind address (use 0.0.0.0 for remote access)
# BRIDGE_WEB_HOST=127.0.0.1

# === Claude Code ===

# Default working directory
BRIDGE_CLAUDE_WORKDIR=/home/user/projects

# Claude CLI binary (if not in PATH)
# BRIDGE_CLAUDE_BIN=claude

# Skip permission prompts (set to false for safer operation)
# BRIDGE_CLAUDE_SKIP_PERMISSIONS=true

# === Proxy (optional) ===

# HTTP proxy for Telegram API and Claude CLI
# BRIDGE_PROXY=http://127.0.0.1:8118

# === Voice / Whisper (optional) ===

# Whisper model size: tiny, base, small, medium, large
# BRIDGE_WHISPER_MODEL=small

# Speech recognition language (ISO 639-1 code)
# BRIDGE_WHISPER_LANGUAGE=en

# Device for Whisper: auto, cuda, cpu
# BRIDGE_WHISPER_DEVICE=auto

# Compute type: float16 (GPU), int8 (CPU)
# BRIDGE_WHISPER_COMPUTE_TYPE=float16

# Custom paths to binaries (if not in PATH)
# BRIDGE_FFMPEG_BIN=ffmpeg
# BRIDGE_WHISPERX_BIN=whisperx

# === Paths ===

# Cache directory for uploads and whisper output
# BRIDGE_CACHE_DIR=~/.cache/claude-bridge

# === Terminal ===

# Default terminal dimensions
# BRIDGE_TMUX_COLS=200
# BRIDGE_TMUX_ROWS=50

# === Timeouts (seconds) ===

# Max Claude CLI execution time (default: 900 = 15 min)
# BRIDGE_MAX_EXECUTION_DURATION=900

# Whisper transcription timeout
# BRIDGE_WHISPER_TIMEOUT=120

# FFmpeg conversion timeout
# BRIDGE_FFMPEG_TIMEOUT=30
